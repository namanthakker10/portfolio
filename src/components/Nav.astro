---
import PillButton from "./PillButton.astro";

const navLinks = [
  { href: "#about", label: "About" },
  { href: "#experience", label: "Experience" },
  { href: "#impact", label: "Impact" },
  { href: "#work", label: "Work" },
  { href: "#stack", label: "Stack" },
  { href: "#contact", label: "Contact" },
];
---

<header class="fixed top-0 inset-x-0 z-50 border-b border-line/80 bg-bg/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 md:px-10">
    <a
      href="/"
      class="shrink-0 font-mono text-sm font-bold tracking-[0.2em] text-ink transition-colors hover:text-accent"
      aria-label="NT — home"
    >
      NT
    </a>

    <nav class="hidden md:flex md:items-center md:gap-8" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link
            data-nav-target={link.href.slice(1)}
            class="text-[0.7rem] font-medium uppercase tracking-[0.15em] text-muted transition-colors hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4">
      <PillButton href="#contact" class="hidden md:inline-flex">Get in touch</PillButton>
      <button
        id="nav-menu-toggle"
        class="flex h-9 w-9 items-center justify-center text-ink md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="nav-burger relative block h-3.5 w-5">
          <span class="absolute left-0 top-0 h-px w-full bg-ink transition-transform"></span>
          <span class="absolute left-0 bottom-0 h-px w-full bg-ink transition-transform"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<div
  id="nav-mobile-menu"
  class="pointer-events-none fixed inset-x-0 bottom-0 top-16 z-40 flex -translate-y-4 flex-col justify-between border-t border-line bg-bg px-6 py-10 opacity-0 transition-all duration-300 md:hidden"
>
  <nav class="flex flex-col gap-6" aria-label="Mobile">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          data-nav-link
          data-nav-target={link.href.slice(1)}
          class="text-3xl font-semibold tracking-tight text-ink"
        >
          {link.label}
        </a>
      ))
    }
  </nav>
  <PillButton href="#contact" class="w-fit">Get in touch</PillButton>
</div>

<script>
  function setupNavMenu() {
    const toggle = document.getElementById("nav-menu-toggle");
    const menu = document.getElementById("nav-mobile-menu");
    if (!toggle || !menu) return;

    const closeMenu = () => {
      menu.classList.add("pointer-events-none", "opacity-0", "-translate-y-4");
      toggle.setAttribute("aria-expanded", "false");
    };

    const openMenu = () => {
      menu.classList.remove("pointer-events-none", "opacity-0", "-translate-y-4");
      toggle.setAttribute("aria-expanded", "true");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));
    document.addEventListener("astro:before-swap", closeMenu);
  }

  function setupScrollSpy() {
    const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
    if (!navLinks.length) return;

    const setActive = (id: string | null) => {
      navLinks.forEach((link) => {
        const isActive = link.dataset.navTarget === id;
        link.classList.toggle("text-accent", isActive);
        link.classList.toggle("text-muted", !isActive && link.closest("nav")?.getAttribute("aria-label") === "Primary");
        link.classList.toggle("text-ink", !isActive && link.closest("nav")?.getAttribute("aria-label") === "Mobile");
        if (isActive) link.setAttribute("aria-current", "page");
        else link.removeAttribute("aria-current");
      });
    };

    const sections = Array.from(navLinks)
      .map((link) => document.getElementById(link.dataset.navTarget ?? ""))
      .filter((el): el is HTMLElement => el !== null);
    if (!sections.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        if (visible.length > 0) {
          setActive((visible[0].target as HTMLElement).id);
        }
      },
      { rootMargin: "-30% 0px -60% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] }
    );

    sections.forEach((section) => observer.observe(section));
  }

  document.addEventListener("astro:page-load", setupNavMenu);
  document.addEventListener("astro:page-load", setupScrollSpy);
</script>
