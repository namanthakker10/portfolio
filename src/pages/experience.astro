---
import Layout from "../layouts/Layout.astro";
import SectionLabel from "../components/SectionLabel.astro";
import { experience, type ExperienceCategory } from "../data/experience";

const categoryStyles: Record<ExperienceCategory, { node: string; org: string; tag: string }> = {
  work: {
    node: "border-accent bg-accent",
    org: "text-accent",
    tag: "Work",
  },
  leadership: {
    node: "border-accent/60 bg-accent/30",
    org: "text-accent/80",
    tag: "Leadership",
  },
  education: {
    node: "border-white/60 bg-bg",
    org: "text-ink",
    tag: "Education",
  },
};
---

<Layout title="Experience">
  <section class="mx-auto max-w-6xl px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Experience" />
    <h1 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Roadmap
    </h1>
    <p data-reveal class="mt-6 max-w-xl text-muted md:text-lg">
      Work on the right, education on the left — scroll to follow the timeline.
    </p>

    <div data-timeline class="relative mt-24 pb-12">
      <div data-timeline-spine class="absolute left-4 top-0 h-full w-px bg-line md:left-1/2"></div>
      <div
        data-timeline-comet
        class="absolute left-4 top-0 h-3 w-3 -translate-x-1/2 rounded-full bg-accent shadow-[0_0_18px_4px_rgba(47,107,255,0.55)] md:left-1/2"
      >
      </div>

      {
        experience.map((entry) => {
          const styles = categoryStyles[entry.category];
          const isLeft = entry.side === "left";
          return (
            <div class="relative py-8 md:py-10">
              <div
                data-timeline-node
                class={`absolute left-4 top-7 h-3 w-3 -translate-x-1/2 rounded-full border-2 md:left-1/2 ${styles.node}`}
              />
              <div
                data-timeline-card
                class={`ml-12 rounded-2xl border border-line bg-white/[0.015] p-6 md:ml-0 md:w-[calc(50%-2.5rem)] ${
                  isLeft ? "md:mr-auto md:text-right" : "md:ml-auto md:text-left"
                }`}
              >
                <span
                  class={`font-mono text-[0.65rem] uppercase tracking-[0.2em] ${styles.org} opacity-80`}
                >
                  {styles.tag}
                </span>
                <h2 class="mt-2 text-xl font-bold text-ink md:text-2xl">{entry.org}</h2>
                <p class="mt-1 text-sm font-medium text-muted md:text-base">{entry.role}</p>
                <p class="mt-3 font-mono text-xs uppercase tracking-[0.15em] text-muted-dim">
                  {entry.period}
                </p>
                {entry.description && (
                  <p class="mt-4 text-sm leading-relaxed text-muted">{entry.description}</p>
                )}
              </div>
            </div>
          );
        })
      }
    </div>
  </section>
</Layout>
