---
import Layout from "../layouts/Layout.astro";
import SectionLabel from "../components/SectionLabel.astro";
import StackItemCard from "../components/StackItemCard.astro";
import { stackGroups } from "../data/stack";
---

<Layout title="Stack">
  <section class="mx-auto max-w-6xl px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Stack" />
    <h1 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Tools &amp; skills
    </h1>

    <div class="mt-20 flex flex-col gap-16">
      {
        stackGroups.map((group) => (
          <div>
            <h2 data-reveal class="font-mono text-xs uppercase tracking-[0.25em] text-muted">
              {group.label}
            </h2>
            <div
              data-stagger-group
              class="mt-6 grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6"
            >
              {group.items.map((item) => (
                <StackItemCard item={item} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
