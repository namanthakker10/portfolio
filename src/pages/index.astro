---
import Layout from "../layouts/Layout.astro";
import PillButton from "../components/PillButton.astro";
import BostonClock from "../components/BostonClock.astro";
import SectionLabel from "../components/SectionLabel.astro";
import StackItemCard from "../components/StackItemCard.astro";
import { experience, type ExperienceCategory } from "../data/experience";
import { impactStats } from "../data/impact";
import { workProjects } from "../data/work";
import { stackGroups } from "../data/stack";

const categoryStyles: Record<ExperienceCategory, { node: string; org: string; tag: string }> = {
  work: {
    node: "border-accent bg-accent",
    org: "text-accent",
    tag: "Work",
  },
  leadership: {
    node: "border-accent/60 bg-accent/30",
    org: "text-accent/80",
    tag: "Leadership",
  },
  education: {
    node: "border-white/60 bg-bg",
    org: "text-ink",
    tag: "Education",
  },
};

let lastTimelineYear: string | null = null;
const timelineEntries = experience.map((entry) => {
  const matches = entry.period.match(/20\d{2}/g);
  const year = matches ? matches[matches.length - 1] : null;
  const showYear = year !== null && year !== lastTimelineYear;
  if (year) lastTimelineYear = year;
  return { ...entry, year, showYear };
});

const contactLinks = [
  { label: "Email", href: "mailto:thakker.n@northeastern.edu" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/namanthakker" },
  { label: "GitHub", href: "https://github.com/namanthakker10" },
  { label: "Resume", href: "/resume.pdf" },
];

const inputClasses =
  "w-full rounded-lg border border-line bg-white/[0.03] px-4 py-3 text-sm text-ink placeholder:text-muted-dim focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors";
const labelClasses = "text-xs font-medium uppercase tracking-[0.2em] text-muted";
---

<Layout title="Home">
  <section
    id="home"
    class="relative flex min-h-[calc(100vh-4rem)] scroll-mt-16 flex-col justify-center overflow-hidden px-6 py-20 md:px-10"
  >
    <div class="pointer-events-none absolute right-6 top-8 md:right-10 md:top-10">
      <BostonClock />
    </div>

    <div class="mx-auto grid w-full max-w-7xl gap-12 md:grid-cols-[1.5fr_0.5fr] md:items-end">
      <div data-hero>
        <h1
          class="font-sans text-[15vw] font-extrabold leading-[0.88] tracking-tighter text-ink md:text-[8vw]"
        >
          <span data-hero-line class="block overflow-hidden"
            ><span class="block">Naman</span></span
          >
          <span data-hero-line class="block overflow-hidden"
            ><span class="block">Thakker</span></span
          >
        </h1>

        <p data-hero-fade class="mt-8 max-w-xl text-lg text-muted md:text-xl">
          Better operations. Cleaner data. Real solutions.
        </p>

        <div data-hero-fade class="mt-10 flex flex-wrap gap-4">
          <PillButton href="mailto:thakker.n@northeastern.edu">Email</PillButton>
          <PillButton href="https://www.linkedin.com/in/namanthakker" external>LinkedIn</PillButton>
          <PillButton href="/resume.pdf" external>Resume</PillButton>
        </div>
      </div>

      <div
        data-reveal
        class="relative mx-auto aspect-[3/4] w-full max-w-[220px] overflow-hidden rounded-2xl border border-dashed border-line md:mx-0 md:max-w-none"
      >
        <img
          src="/photo.jpg"
          alt="Naman Thakker"
          class="h-full w-full object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div
          style="display:none"
          class="absolute inset-0 flex-col items-center justify-center gap-2 bg-white/[0.02] text-center"
        >
          <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-muted-dim">Photo</span>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="mx-auto max-w-7xl scroll-mt-16 px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="About" />

    <div class="mt-8 grid gap-16 md:grid-cols-[0.55fr_1fr] md:items-start">
      <div
        data-reveal
        class="relative mx-auto aspect-[3/4] w-full max-w-sm overflow-hidden rounded-2xl border border-dashed border-line md:mx-0"
      >
        <img
          src="/about-photo.jpg"
          alt="Naman Thakker"
          class="h-full w-full object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div
          style="display:none"
          class="absolute inset-0 flex-col items-center justify-center gap-2 bg-white/[0.02] text-center"
        >
          <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-muted-dim">Photo</span>
        </div>
      </div>

      <div class="flex flex-col gap-8">
        <h2 data-reveal class="text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
          About
        </h2>

        <p data-reveal class="font-mono text-xs uppercase tracking-[0.2em] text-muted-dim">
          Northeastern &apos;28 &middot; Boston &middot; Supply Chain + Data Science
        </p>

        <div class="flex max-w-2xl flex-col gap-6 text-lg leading-relaxed text-muted md:text-xl">
          <p data-reveal>
            Supply chain and data science by the degree — which meant learning to ask why
            operations fail before asking how to fix them. The pattern showed up early: most
            people analyze the problem. I&apos;d rather build something that solves it.
          </p>
          <p data-reveal>
            That instinct carried through everything. At TJX I wasn&apos;t just mapping processes
            — I was building the dashboards, writing the queries, and shipping the tools that made
            the insights actually usable. At MedTourEasy I turned 300+ patient records into a
            strategic expansion model. At Bhairav Exports I built a forecasting model that cut
            costs 7.5% in a quarter.
          </p>
          <p data-reveal>
            The real gap I keep finding isn&apos;t the analysis — it&apos;s the execution.
            Everyone can spot what&apos;s broken. The harder part is building something clean
            enough to actually fix it and shipping it before the problem moves. That&apos;s the
            part I&apos;m drawn to.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="experience" class="mx-auto max-w-6xl scroll-mt-16 px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Experience" />
    <h2 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Roadmap
    </h2>
    <p data-reveal class="mt-6 max-w-xl text-muted md:text-lg">
      Work on the right, education on the left — scroll to follow the timeline.
    </p>

    <div data-timeline class="relative mt-24 pb-12">
      <div
        data-timeline-spine
        class="absolute left-4 top-0 z-0 h-full w-px bg-line md:left-1/2"
      ></div>
      <div
        data-timeline-progress
        class="absolute left-4 top-0 z-[1] w-px bg-accent md:left-1/2"
        style="height:0%"
      ></div>
      <div
        data-timeline-comet
        class="absolute left-4 top-0 z-[2] h-3 w-3 -translate-x-1/2 rounded-full bg-accent shadow-[0_0_18px_4px_rgba(47,107,255,0.55)] md:left-1/2"
      >
      </div>

      {
        timelineEntries.map((entry) => {
          const styles = categoryStyles[entry.category];
          const isLeft = entry.side === "left";
          return (
            <div class="relative py-8 md:py-10">
              {entry.showYear && (
                <span class="absolute left-4 top-0 z-[3] -translate-x-1/2 -translate-y-1/2 rounded-full border border-line bg-bg px-2.5 py-1 font-mono text-[0.65rem] font-bold tracking-[0.1em] text-muted-dim md:left-1/2">
                  {entry.year}
                </span>
              )}
              <div
                data-timeline-node
                class={`absolute left-4 top-7 z-[3] h-3 w-3 -translate-x-1/2 rounded-full border-2 md:left-1/2 ${styles.node}`}
              />
              <div
                data-timeline-card
                class={`ml-12 rounded-2xl border border-line bg-white/[0.015] p-6 md:ml-0 md:w-[calc(50%-2.5rem)] ${
                  isLeft ? "md:mr-auto md:text-right" : "md:ml-auto md:text-left"
                }`}
              >
                <span
                  class={`font-mono text-[0.65rem] uppercase tracking-[0.2em] ${styles.org} opacity-80`}
                >
                  {styles.tag}
                </span>
                <h3 class="mt-2 text-xl font-bold text-ink md:text-2xl">{entry.org}</h3>
                <p class="mt-1 text-sm font-medium text-muted md:text-base">{entry.role}</p>
                {entry.description && (
                  <p class="mt-4 text-sm leading-relaxed text-muted">{entry.description}</p>
                )}
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <section id="impact" class="mx-auto max-w-7xl scroll-mt-16 px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Impact" />
    <h2 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Numbers that moved
    </h2>

    <div
      data-stagger-group
      class="mt-20 grid grid-cols-2 gap-x-6 gap-y-16 border-t border-line pt-16 md:grid-cols-4 md:gap-x-10"
    >
      {
        impactStats.map((stat) => (
          <div class="border-l border-line pl-5">
            <p class="font-sans text-5xl font-extrabold tracking-tight text-ink md:text-6xl">
              <span
                data-counter={stat.value}
                data-counter-decimals={stat.decimals ?? 0}
                data-counter-suffix={stat.suffix}
              >
                0{stat.suffix}
              </span>
            </p>
            <p class="mt-4 text-sm font-medium uppercase tracking-[0.1em] text-muted">
              {stat.label}
            </p>
            {stat.note && <p class="mt-1 text-xs text-muted-dim">{stat.note}</p>}
          </div>
        ))
      }
    </div>
  </section>

  <section id="work" class="mx-auto max-w-6xl scroll-mt-16 px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Work" />
    <h2 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Selected work
    </h2>

    <div class="mt-20 flex flex-col divide-y divide-line border-t border-line">
      {
        workProjects.map((project, i) => (
          <div data-reveal class="grid gap-6 py-14 md:grid-cols-[auto_1fr] md:gap-16">
            <span class="font-mono text-sm text-muted-dim">{String(i + 1).padStart(2, "0")}</span>

            <div>
              <h3 class="text-3xl font-extrabold tracking-tight text-ink md:text-4xl">
                {project.title}
              </h3>
              <p class="mt-4 max-w-2xl text-muted md:text-lg">{project.description}</p>

              <div class="mt-6 flex flex-wrap gap-3">
                {project.highlights.map((h) => (
                  <span class="rounded-full border border-white/20 px-4 py-1.5 text-xs font-medium uppercase tracking-[0.1em] text-ink">
                    {h}
                  </span>
                ))}
              </div>

              <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2">
                {project.stack.map((s) => (
                  <span class="font-mono text-xs uppercase tracking-[0.1em] text-accent/80">
                    {s}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section id="stack" class="mx-auto max-w-6xl scroll-mt-16 px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Stack" />
    <h2 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Tools &amp; skills
    </h2>

    <div class="mt-20 flex flex-col gap-16">
      {
        stackGroups.map((group) => (
          <div>
            <h3 data-reveal class="font-mono text-xs uppercase tracking-[0.25em] text-muted">
              {group.label}
            </h3>
            <div
              data-stagger-group
              class="mt-6 grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6"
            >
              {group.items.map((item) => (
                <StackItemCard item={item} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section id="contact" class="mx-auto max-w-6xl scroll-mt-16 px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Contact" />
    <h2 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Let's talk
    </h2>

    <div class="mt-16 grid gap-16 md:grid-cols-2 md:gap-24">
      <div data-reveal class="flex flex-col justify-between gap-12">
        <div class="flex flex-wrap gap-x-8 gap-y-4">
          {
            contactLinks.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="text-sm font-medium uppercase tracking-[0.15em] text-ink transition-colors hover:text-accent"
              >
                {link.label}
              </a>
            ))
          }
        </div>
        <p class="text-2xl font-semibold tracking-tight text-muted md:text-3xl">
          Hard problems welcome.
        </p>
      </div>

      <form
        id="contact-form"
        data-reveal
        action="https://formspree.io/f/xgodbjyy"
        method="POST"
        class="flex flex-col gap-6"
      >
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="flex flex-col gap-2">
            <label for="name" class={labelClasses}>Name</label>
            <input id="name" name="name" type="text" required class={inputClasses} placeholder="Your name" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="email" class={labelClasses}>Email</label>
            <input id="email" name="email" type="email" required class={inputClasses} placeholder="you@example.com" />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="subject" class={labelClasses}>Subject</label>
          <input id="subject" name="subject" type="text" required class={inputClasses} placeholder="What's this about?" />
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class={labelClasses}>Message</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class={`${inputClasses} resize-none`}
            placeholder="Tell me a bit more..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="mt-2 w-fit rounded-full bg-accent px-7 py-3 text-xs font-semibold uppercase tracking-[0.15em] text-white transition-opacity hover:opacity-90 disabled:opacity-50"
        >
          Send Message
        </button>

        <p id="contact-form-status" class="text-sm text-muted" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</Layout>

<script>
  function setupContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    if (!form) return;
    const status = document.getElementById("contact-form-status");
    const button = form.querySelector("button[type=submit]") as HTMLButtonElement | null;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!status || !button) return;

      button.disabled = true;
      status.textContent = "Sending...";

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });

        if (response.ok) {
          status.textContent = "Message sent — I'll get back to you soon.";
          form.reset();
        } else {
          status.textContent = "Something went wrong. Try emailing me directly instead.";
        }
      } catch {
        status.textContent = "Something went wrong. Try emailing me directly instead.";
      } finally {
        button.disabled = false;
      }
    });
  }

  document.addEventListener("astro:page-load", setupContactForm);
</script>
