---
import Layout from "../layouts/Layout.astro";
import SectionLabel from "../components/SectionLabel.astro";
import { impactStats } from "../data/impact";
---

<Layout title="Impact">
  <section class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
    <SectionLabel label="Impact" />
    <h1 data-reveal class="mt-8 text-4xl font-extrabold leading-[0.95] tracking-tight text-ink md:text-6xl">
      Numbers that moved
    </h1>

    <div
      data-stagger-group
      class="mt-20 grid grid-cols-2 gap-x-6 gap-y-16 border-t border-line pt-16 md:grid-cols-4 md:gap-x-10"
    >
      {
        impactStats.map((stat) => (
          <div class="border-l border-line pl-5">
            <p class="font-sans text-5xl font-extrabold tracking-tight text-ink md:text-6xl">
              <span
                data-counter={stat.value}
                data-counter-decimals={stat.decimals ?? 0}
                data-counter-suffix={stat.suffix}
              >
                0{stat.suffix}
              </span>
            </p>
            <p class="mt-4 text-sm font-medium uppercase tracking-[0.1em] text-muted">
              {stat.label}
            </p>
            {stat.note && <p class="mt-1 text-xs text-muted-dim">{stat.note}</p>}
          </div>
        ))
      }
    </div>
  </section>
</Layout>
